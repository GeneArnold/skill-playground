# Copy this file to `.env` and fill in the keys you have.
# You don't need all of them — the playground only offers models whose key is set.

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (groq.com) — fast host for open models (Llama, GPT-OSS…). Keys start `gsk_`.
GROQ_API_KEY=

# xAI (Grok) — https://console.x.ai/  (different from Groq! keys start with `xai-`)
XAI_API_KEY=

# DeepSeek — https://platform.deepseek.com/  (optional, OpenAI-compatible)
DEEPSEEK_API_KEY=

# Ollama — local models, no API key, works offline (great on a plane!).
# Install from https://ollama.com, then `ollama pull qwen2.5:7b`.
# Local models appear automatically when the Ollama server is running.
# Only tool-capable models are offered (qwen2.5, llama3.2, gpt-oss); Gemma is
# excluded because it doesn't support tool calling.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1

# Where skills live (relative to repo root). Leave as-is unless you move them.
SKILLS_DIR=../skills

# Max seconds a single skill script may run before it's killed.
SCRIPT_TIMEOUT_SECONDS=10

# Required if you plan to use the Tavily Web Search Skill
TAVILY_API_KEY=
